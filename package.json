{
  "name": "jira-scanner",
  "version": "1.0.0",
  "description": "Local Electron app for scanning Jira issues",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "node scripts/release.js mac",
    "build:win": "node scripts/release.js win",
    "build:linux": "node scripts/release.js linux"
  },
  "build": {
    "appId": "com.jirascanner.app",
    "productName": "Jira Scanner",
    "mac": {
      "target": "dmg",
      "identity": null,
      "icon": "build-icon.icns"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^30",
    "electron-builder": "^24"
  }
}
